{
  "name": "n8n-nodes-zena",
  "version": "0.7.1",
  "description": "n8n nodes to connect Zena — WhatsApp AI CRM for MENA",
  "keywords": [
    "n8n-community-node-package",
    "zena",
    "whatsapp",
    "crm",
    "ai"
  ],
  "license": "MIT",
  "homepage": "https://zena.chat",
  "author": {
    "name": "Fictoralabs",
    "email": "hello@fictoralabs.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Fictoralabs/n8n-nodes-zena.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "for f in src/nodes/*/*.svg; do d=\"dist/${f#src/}\"; mkdir -p \"$(dirname \"$d\")\" && cp \"$f\" \"$d\"; done",
    "dev": "tsc --watch",
    "format": "prettier src --write",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ZenaApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Zena/Zena.node.js",
      "dist/nodes/ZenaTrigger/ZenaTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "n8n-workflow": "*",
    "typescript": "^5.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
